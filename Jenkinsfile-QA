@Library('cicd-scripts')

def PIPELINE_AGENT_LABEL    = 'QA'
def DOCKER_MAVEN_IMAGE      = 'maven:3-eclipse-temurin-21'
def DOCKER_CLICKHOUSE_IMAGE = "${env.AERIUS_REGISTRY_URL ?: ''}database:${env.AERIUS_IMAGE_TAG ?: 'latest'}"

cicdPipeline(
  agentLabel                    : PIPELINE_AGENT_LABEL,

  qaJunitEnabled                : !cicdHasFlag('TEST_UNITTESTS_DISABLE'),
  qaJunitTestResults            : '**/TEST-*.xml',

  environment : [
    TZ                      : 'Europe/Amsterdam'
  ],

  environmentScripts : [
    FLAG_SETTINGS_SCRIPT  : 'mktemp -u -p . tmp.XXXXXX.envsh'
  ]) {

  cicdStage('Docker preparation') {
    sh '''
      cd docker
      PROFILE=integrationtests "${CICD_SCgotRIPTS_DIR}"/docker/images_v1.0.sh --no-push
    '''
  }

  cicdStage('All tests') {
    docker.image(DOCKER_CLICKHOUSE_IMAGE``)
        .withRun('-P') { c ->

      // Get random port from the database container
      // Random ports are important for running multiple jobs in parallel because the jobs must not use the same port on the host
      // Then wait until postgres is up
      sh '''
        port=$(docker inspect --format='{{(index (index .NetworkSettings.Ports "8123/tcp") 0).HostPort}}' ''' + c.id + ''')
        while ! curl "http://localhost:${port}/" 2>&1 | grep '52'; do echo 'waiting for ClickHouse'; sleep 1; done;
      '''

      docker.image(DOCKER_MAVEN_IMAGE).inside("--link ${c.id}:database") {
        withCredentials([string(credentialsId: 'SONAR_TOKEN', variable: 'SONAR_TOKEN')]) {

          sh '''
            mvn -f source/pom.xml \
              clean verify org.sonarsource.scanner.maven:sonar-maven-plugin::sonar -Psonar,failsafe --no-transfer-progress -Dmaven.test.failure.ignore=true \
              -Dspring.datasource.url=jdbc:ch:http://database:8123/smm -Dspring.datasource.username=aerius -Dspring.datasource.password=aerius
          '''

        }
      }
    }
  }

}
